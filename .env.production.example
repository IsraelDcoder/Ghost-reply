# Production Environment Variables
# Copy this to .env and fill in your actual values before deploying

# Backend API URL (set to your hosted backend, e.g., https://api.ghostreply.com)
EXPO_PUBLIC_DOMAIN=https://ghost-reply.onrender.com

# Sentry Crash Reporting (optional for error tracking)
EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Database URL (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# OpenRouter API Configuration
AI_INTEGRATIONS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_INTEGRATIONS_OPENROUTER_API_KEY=sk-or-v1-xxx

# Firebase Configuration (optional for analytics)
FIREBASE_API_KEY=xxx
FIREBASE_AUTH_DOMAIN=xxx
FIREBASE_PROJECT_ID=xxx

# RevenueCat Configuration (optional for subscriptions)
REVENUECAT_API_KEY=xxx

# Node Environment
NODE_ENV=production
